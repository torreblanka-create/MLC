# ─── Google Cloud ───────────────────────────────
VITE_GCS_BUCKET=gmlc-induccion-media
VITE_API_BASE_URL=https://induccion-api-xxxx-uc.a.run.app

# ─── Firma Digital (e-certchile / TOC / Acepta) ─
FEA_PROVIDER=ecertchile
FEA_API_ENDPOINT=https://api.ecertchile.cl/v2/sign
FEA_CLIENT_ID=
FEA_CLIENT_SECRET=
FEA_CERT_SERIAL=

# ─── Google Cloud Vision API (OCR Cédula) ────────
GOOGLE_VISION_API_KEY=
GOOGLE_CLOUD_PROJECT=

# ─── Biometría facial ───────────────────────────
# face-api.js: no key needed (procesado en navegador)
# AWS Rekognition o Azure Face API:
FACE_API_PROVIDER=faceapijs
FACE_API_KEY=
FACE_API_ENDPOINT=
FACE_MIN_CONFIDENCE=85

# ─── Email / cPanel ─────────────────────────────
SMTP_HOST=mail.tecktur.cl
SMTP_PORT=465
SMTP_USER=induccionmlc@tecktur.cl
SMTP_PASS=
MAIL_FROM=induccionmlc@tecktur.cl
MAIL_NOTIFY=rrhh@tecktur.cl
